{
  "id": "math314-final-practice",
  "title": "Math 314 Final Practice",
  "description": "Linear algebra practice covering vector spaces, transformations, eigenvalues, and diagonalization.",
  "image": "assets/burning_in_hell.jpg",
  "questions": [

    { "id": 1, "prompt": "Which statement best describes the sets built from vectors u, v, w, z regarding orthogonality, independence, span, and basis in R^3?", "type": "multiple-choice", "choices": [
      {"label":"u,v,w form an orthogonal basis for R^3; sets with z remain independent but not fully orthogonal","value":"A"},
      {"label":"All sets are dependent","value":"B"},
      {"label":"No set spans R^3","value":"C"},
      {"label":"All sets are orthogonal","value":"D"}
    ], "correctAnswer": "A", "explanation": "u,v,w are orthogonal → basis. Sets including z lose orthogonality but remain independent." },

    { "id": 2, "prompt": "Given rref(A) with pivots in columns 1 and 2, what must be true?", "type": "multiple-choice", "choices": [
      {"label":"v1,v2 independent; v3,v4 depend on them","value":"A"},
      {"label":"All vectors independent","value":"B"},
      {"label":"Only v4 independent","value":"C"},
      {"label":"None independent","value":"D"}
    ], "correctAnswer": "A", "explanation": "Pivot columns correspond to independent vectors." },

    { "id": 3, "prompt": "Three independent vectors in R^4 span what?", "type": "multiple-choice", "choices": [
      {"label":"R^4","value":"A"},
      {"label":"A 3D subspace","value":"B"},
      {"label":"A line","value":"C"},
      {"label":"Nothing","value":"D"}
    ], "correctAnswer": "B", "explanation": "Dimension equals number of independent vectors." },

    { "id": 4, "prompt": "A 3x3 matrix has 2 eigenvalues with 1D eigenspaces. Is it diagonalizable?", "type": "multiple-choice", "choices": [
      {"label":"Yes","value":"A"},
      {"label":"No","value":"B"},
      {"label":"Only if symmetric","value":"C"},
      {"label":"Cannot determine","value":"D"}
    ], "correctAnswer": "B", "explanation": "Need 3 independent eigenvectors." },

    { "id": 5, "prompt": "A 7x6 matrix has nullity 4. What is its rank?", "type": "multiple-choice", "choices": [
      {"label":"2","value":"A"},
      {"label":"3","value":"B"},
      {"label":"4","value":"C"},
      {"label":"6","value":"D"}
    ], "correctAnswer": "A", "explanation": "Rank + nullity = 6." },

    { "id": 6, "prompt": "If W ⊂ R^5 has dimension 2, what is dim(W^⊥)?", "type": "multiple-choice", "choices": [
      {"label":"1","value":"A"},
      {"label":"2","value":"B"},
      {"label":"3","value":"C"},
      {"label":"5","value":"D"}
    ], "correctAnswer": "C", "explanation": "dim(W)+dim(W⊥)=5." },

    { "id": 7, "prompt": "Why must 4 vectors in R^3 be dependent?", "type": "multiple-choice", "choices": [
      {"label":"Too many vectors","value":"A"},
      {"label":"They are orthogonal","value":"B"},
      {"label":"They span R^4","value":"C"},
      {"label":"They are zero","value":"D"}
    ], "correctAnswer": "A", "explanation": "Max independent vectors in R^3 is 3." },

    { "id": 8, "prompt": "A 2D subspace of R^3 is what geometrically?", "type": "multiple-choice", "choices": [
      {"label":"Line","value":"A"},
      {"label":"Plane","value":"B"},
      {"label":"Point","value":"C"},
      {"label":"Full space","value":"D"}
    ], "correctAnswer": "B", "explanation": "Dimension 2 → plane." },

    { "id": 9, "prompt": "When is a linear transformation injective?", "type": "multiple-choice", "choices": [
      {"label":"Kernel = {0}","value":"A"},
      {"label":"Det=0","value":"B"},
      {"label":"Square matrix","value":"C"},
      {"label":"Full row rank","value":"D"}
    ], "correctAnswer": "A", "explanation": "Injective ↔ trivial null space." },

    { "id": 10, "prompt": "When is a matrix diagonalizable?", "type": "multiple-choice", "choices": [
      {"label":"n independent eigenvectors","value":"A"},
      {"label":"det=0","value":"B"},
      {"label":"square only","value":"C"},
      {"label":"distinct rows","value":"D"}
    ], "correctAnswer": "A", "explanation": "Needs eigenbasis." },

    { "id": 11, "prompt": "What determines if a matrix is invertible?", "type": "multiple-choice", "choices": [
      {"label":"Full pivots","value":"A"},
      {"label":"Zero determinant","value":"B"},
      {"label":"More rows than columns","value":"C"},
      {"label":"Orthogonal rows","value":"D"}
    ], "correctAnswer": "A", "explanation": "Invertible ↔ pivots in all columns." },

    { "id": 12, "prompt": "If eigenvalues are known, how is A^{-1} related?", "type": "multiple-choice", "choices": [
      {"label":"Use diagonalization","value":"A"},
      {"label":"Transpose it","value":"B"},
      {"label":"Square it","value":"C"},
      {"label":"Ignore eigenvalues","value":"D"}
    ], "correctAnswer": "A", "explanation": "A = PDP^{-1} simplifies inversion." },

    { "id": 13, "prompt": "If eigenvalues are ±1, what is A^2?", "type": "multiple-choice", "choices": [
      {"label":"Identity","value":"A"},
      {"label":"Zero","value":"B"},
      {"label":"Same as A","value":"C"},
      {"label":"Diagonal only","value":"D"}
    ], "correctAnswer": "A", "explanation": "Squares of ±1 are 1." },

    { "id": 14, "prompt": "Determinant of a diagonalizable matrix equals?", "type": "multiple-choice", "choices": [
      {"label":"Product of eigenvalues","value":"A"},
      {"label":"Sum of eigenvalues","value":"B"},
      {"label":"Trace","value":"C"},
      {"label":"Zero","value":"D"}
    ], "correctAnswer": "A", "explanation": "Det = product of eigenvalues." },

    { "id": 15, "prompt": "Which systems form a vector space?", "type": "multiple-choice", "choices": [
      {"label":"Homogeneous systems","value":"A"},
      {"label":"Inconsistent systems","value":"B"},
      {"label":"Random systems","value":"C"},
      {"label":"None","value":"D"}
    ], "correctAnswer": "A", "explanation": "Solution sets of Ax=0 are subspaces." },

    { "id": 16, "prompt": "Rank(A)=2 for 3x3. What is nullity?", "type": "multiple-choice", "choices": [
      {"label":"1","value":"A"},
      {"label":"2","value":"B"},
      {"label":"3","value":"C"},
      {"label":"0","value":"D"}
    ], "correctAnswer": "A", "explanation": "Rank-nullity." },

    { "id": 17, "prompt": "If dim(null(A^T))=2 for 3x3, what about diagonalizability?", "type": "multiple-choice", "choices": [
      {"label":"Not enough info","value":"A"},
      {"label":"Yes","value":"B"},
      {"label":"No","value":"C"},
      {"label":"Always","value":"D"}
    ], "correctAnswer": "A", "explanation": "Need eigenvector info." },

    { "id": 18, "prompt": "Which matrices may fail to diagonalize?", "type": "multiple-choice", "choices": [
      {"label":"Repeated eigenvalues","value":"A"},
      {"label":"Distinct eigenvalues","value":"B"},
      {"label":"Identity","value":"C"},
      {"label":"Orthogonal","value":"D"}
    ], "correctAnswer": "A", "explanation": "May lack eigenvectors." },

    { "id": 19, "prompt": "Which guarantees diagonalizability?", "type": "multiple-choice", "choices": [
      {"label":"Distinct eigenvalues","value":"A"},
      {"label":"Zero determinant","value":"B"},
      {"label":"Rank deficiency","value":"C"},
      {"label":"Symmetry only","value":"D"}
    ], "correctAnswer": "A", "explanation": "Distinct eigenvalues ⇒ independent eigenvectors." },

    { "id": 20, "prompt": "When is a rotation matrix diagonalizable over R?", "type": "multiple-choice", "choices": [
      {"label":"θ = 0 or π","value":"A"},
      {"label":"Any θ","value":"B"},
      {"label":"Never","value":"C"},
      {"label":"Only θ=π/2","value":"D"}
    ], "correctAnswer": "A", "explanation": "Otherwise eigenvalues are complex." },

    { "id": 21, "prompt": "What property defines symmetric matrices?", "type": "multiple-choice", "choices": [
      {"label":"A = A^T","value":"A"},
      {"label":"A^{-1}=A","value":"B"},
      {"label":"det=1","value":"C"},
      {"label":"Trace=0","value":"D"}
    ], "correctAnswer": "A", "explanation": "Definition of symmetry." }

  ]
}
